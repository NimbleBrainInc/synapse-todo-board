{
  "manifest_version": "0.4",
  "name": "@nimblebraininc/synapse-todo-board",
  "version": "0.2.1",
  "description": "Kanban-style task manager with board and table views, AI-powered triage, and daily reviews",
  "author": {
    "name": "NimbleBrain Inc."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NimbleBrainInc/synapse-todo-board"
  },
  "server": {
    "type": "python",
    "entry_point": "synapse_todo_board.server",
    "mcp_config": {
      "command": "python",
      "args": [
        "-m",
        "synapse_todo_board.server"
      ]
    }
  },
  "_meta": {
    "org.mpaktrust": {
      "mtf_version": "0.1",
      "permissions": {
        "filesystem": "read",
        "network": "none",
        "environment": "read",
        "subprocess": "none",
        "native": "none"
      }
    },
    "ai.nimblebrain/host": {
      "host_version": "1.0",
      "name": "Todo Board",
      "icon": "list-checks",
      "category": "operations",
      "placements": [
        {
          "slot": "sidebar.apps",
          "resourceUri": "ui://todo-board/main",
          "route": "@nimblebraininc/synapse-todo-board",
          "label": "Todo Board",
          "icon": "list-checks"
        },
        {
          "slot": "settings",
          "resourceUri": "ui://todo-board/settings",
          "label": "Todo Board",
          "icon": "list-checks",
          "priority": 100
        }
      ],
      "briefing": {
        "priority": "medium",
        "facets": [
          {
            "name": "completed_tasks",
            "label": "Completed",
            "type": "activity",
            "entity": "task",
            "query": {
              "completed_at": {
                "$gte": "${period.since}"
              }
            },
            "metric": "count",
            "description": "Tasks completed in this period"
          },
          {
            "name": "blocked_tasks",
            "label": "Blocked",
            "type": "attention",
            "entity": "task",
            "query": {
              "column": "blocked",
              "status": "active"
            },
            "metric": "count",
            "description": "Tasks stuck in blocked column"
          },
          {
            "name": "due_today",
            "label": "Due today",
            "type": "upcoming",
            "entity": "task",
            "query": {
              "due_date": "${today}",
              "completed_at": null
            },
            "metric": "count",
            "description": "Tasks due today that aren't done"
          }
        ]
      }
    },
    "ai.nimblebrain/upjack": {
      "upjack_version": "0.1",
      "namespace": "apps/todo-board",
      "display": {
        "name": "Todo Board",
        "icon": "✅",
        "category": "operations"
      },
      "entities": [
        {
          "name": "board",
          "plural": "boards",
          "schema": "schemas/board.schema.json",
          "prefix": "bd",
          "index": true
        },
        {
          "name": "task",
          "plural": "tasks",
          "schema": "schemas/task.schema.json",
          "prefix": "tk",
          "index": true,
          "tools": [
            "get",
            "update",
            "list",
            "search",
            "delete",
            "query_by_relationship",
            "get_related",
            "get_composite"
          ]
        }
      ],
      "skills": [
        {
          "source": "bundled",
          "path": "skills/task-triage/SKILL.md"
        }
      ],
      "hooks": [
        {
          "event": "entity.created",
          "entity": "task",
          "skill": "bundled:task-triage"
        },
        {
          "event": "entity.updated",
          "entity": "task",
          "condition": "$.column changed",
          "skill": "bundled:task-triage"
        }
      ],
      "schedules": [
        {
          "name": "daily-review",
          "cron": "0 9 * * 1-5",
          "skill": "bundled:task-triage",
          "description": "Weekday morning review: flag overdue, stalled, and WIP-exceeded tasks"
        }
      ],
      "views": [
        {
          "name": "all-tasks",
          "entity": "task",
          "description": "All active tasks by priority",
          "filter": "$.status == 'active'",
          "sort": "-priority, position"
        },
        {
          "name": "overdue",
          "entity": "task",
          "description": "Overdue tasks, oldest first",
          "filter": "$.status == 'active' AND $.due_date < today",
          "sort": "due_date"
        },
        {
          "name": "my-tasks",
          "entity": "task",
          "description": "Assigned tasks by priority",
          "filter": "$.status == 'active' AND $.assignee != null",
          "sort": "-priority"
        },
        {
          "name": "board-tasks",
          "entity": "task",
          "description": "Tasks for a specific board, ordered by position",
          "filter": "$.status == 'active' AND $.relationships[rel=belongs_to].target == {board_id}",
          "sort": "position"
        }
      ],
      "context": "context.md",
      "seed": {
        "data": "seed/",
        "run_on_install": true
      }
    }
  }
}
